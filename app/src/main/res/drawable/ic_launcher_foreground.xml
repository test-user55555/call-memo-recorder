<?xml version="1.0" encoding="utf-8"?>
<!--
    アダプティブアイコン フォアグラウンド: 電話ハンドセット + 録音ドット
    108dp x 108dp (safe zone: 72dp center = 18dp margin on each side)
    VectorDrawable: <ellipse> 非対応のため <path> を使用
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- 電話ハンドセット本体（白）
         中央(54,54)周辺に配置。右上に傾いたハンドセット形状。 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
M35,40
C35,36 38,33 42,33
L50,33
C51.1,33 52,33.9 52,35
L52,42
C52,43.1 51.1,44 50,44
L46,44
C45.4,46 45.4,62 46,64
L50,64
C51.1,64 52,64.9 52,66
L52,73
C52,74.1 51.1,75 50,75
L42,75
C38,75 35,72 35,68
C35,68 31,58 31,54
C31,50 35,40 35,40 Z
" />
    <!-- ハンドセット上部（受話器部分） -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
M52,35
C52,33.9 52.9,33 54,33
L66,33
C70,33 73,36 73,40
C73,40 77,50 77,54
C77,58 73,68 73,68
C73,72 70,75 66,75
L54,75
C52.9,75 52,74.1 52,73
L52,66
C52,64.9 52.9,64 54,64
L58,64
C58.6,62 58.6,46 58,44
L54,44
C52.9,44 52,43.1 52,42
L52,35 Z
" />

    <!-- 録音インジケーター（赤い円）右上エリア
         円: cx=78, cy=30, r=10 を path で表現
         path: M(cx-r,cy) A r,r 0 1,0 (cx+r,cy) A r,r 0 1,0 (cx-r,cy) Z -->
    <path
        android:fillColor="#F44336"
        android:pathData="M68,30 A10,10 0 1,0 88,30 A10,10 0 1,0 68,30 Z" />

    <!-- 録音ドット中心の白い丸（cx=78, cy=30, r=4） -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M74,30 A4,4 0 1,0 82,30 A4,4 0 1,0 74,30 Z" />

</vector>
