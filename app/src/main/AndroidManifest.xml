<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 録音権限 -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- フォアグラウンドサービス -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- FOREGROUND_SERVICE_MICROPHONE は API 34+ で必要。targetSdk=28 では不要だが宣言しても無害 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />

    <!-- ネットワーク -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- 通知 (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- 通話状態の検知 (自動録音に必要) -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!-- 発信番号の取得 (Android 9 以下) -->
    <uses-permission
        android:name="android.permission.PROCESS_OUTGOING_CALLS"
        android:maxSdkVersion="28" />

    <!-- 連絡先アクセス (通話相手の名前表示に使用) -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <!-- 通話ログアクセス (発着信番号の取得に使用、API 31+で電話番号がTelephonyCallbackに渡されないため) -->
    <uses-permission android:name="android.permission.READ_CALL_LOG" />

    <!-- ウェイクロック (バックグラウンド録音) -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- 端末起動時にサービスを自動起動 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!--
        ユーザー補助サービスのバインド権限。
        AccessibilityService の利用に必要。
    -->
    <uses-permission android:name="android.permission.BIND_ACCESSIBILITY_SERVICE" />

    <!--
        通話音声キャプチャ権限。
        通常の署名では実行時に付与されないが、宣言することで
        一部の端末/カスタムROM で有効になる場合がある。
        targetSdk=28 ではシステムパーミッション扱い。
    -->
    <uses-permission android:name="android.permission.CAPTURE_AUDIO_OUTPUT" />

    <uses-feature
        android:name="android.hardware.microphone"
        android:required="true" />

    <application
        android:name=".CallMemoApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CallMemoRecorder"
        tools:targetApi="36">

        <!-- メインActivity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.CallMemoRecorder">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 手動録音フォアグラウンドサービス -->
        <service
            android:name=".service.RecordingService"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <!--
            通話連動録音サービス (TelephonyManager ベース)。
            CallMonitorService / CallStateReceiver から呼ばれる。
        -->
        <service
            android:name=".service.CallRecordingService"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <!--
            常駐監視サービス: TelephonyManager で通話状態を監視し録音も行う。
            START_STICKY により OS に強制停止されても自動再起動。
        -->
        <service
            android:name=".service.CallMonitorService"
            android:exported="false"
            android:foregroundServiceType="microphone"
            android:stopWithTask="false" />

        <!--
            ユーザー補助サービスを利用した通話録音サービス。
            - BIND_ACCESSIBILITY_SERVICE 権限が必要
            - 設定 → ユーザー補助 → Call Memo Recorder → ON にすること
            - android:permission により BIND_ACCESSIBILITY_SERVICE のみバインド可能
        -->
        <service
            android:name=".service.CallRecordingAccessibilityService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!--
            通話状態 BroadcastReceiver。
            android:exported="true" が必須。
            exported=false だとシステムからの PHONE_STATE_CHANGED を受信できない。
        -->
        <receiver
            android:name=".receiver.CallStateReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.PHONE_STATE" />
            </intent-filter>
        </receiver>

        <!--
            端末再起動時に監視サービスを自動起動するレシーバー。
        -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
